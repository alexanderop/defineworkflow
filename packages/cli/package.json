{
  "name": "@workflow/cli",
  "version": "0.0.0",
  "bin": {
    "workflow": "./dist/cli.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean --external react --external ink --external @anthropic-ai/sdk",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@workflow/adapters": "workspace:*",
    "@workflow/core": "workspace:*",
    "@workflow/ui": "workspace:*",
    "acorn": "^8.16.0",
    "esbuild": "^0.28.0",
    "neverthrow": "^8.1.0"
  },
  "devDependencies": {
    "@workflow/test-support": "workspace:*",
    "zod": "^4.0.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.100.1"
  }
}
