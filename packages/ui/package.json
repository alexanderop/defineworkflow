{
  "name": "@workflow/ui",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external react --external ink",
    "typecheck": "tsc --noEmit",
    "react-doctor": "npx --yes react-doctor@latest --no-dead-code --fail-on warning",
    "react-doctor:staged": "npx --yes react-doctor@latest --staged --no-dead-code --fail-on warning"
  },
  "dependencies": {
    "@workflow/core": "workspace:*",
    "ink": "^5.0.1",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@workflow/test-support": "workspace:*",
    "ink-testing-library": "^4.0.0"
  }
}
