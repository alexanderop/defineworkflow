{
  "name": "defineworkflow",
  "version": "0.5.0",
  "description": "Deterministic, crash-safe multi-agent workflow engine. Author workflows as TypeScript, orchestrate coding-agent calls with agent()/parallel()/pipeline(), and replay from a journal.",
  "keywords": [
    "agent",
    "agents",
    "ai",
    "claude",
    "cli",
    "codex",
    "durable",
    "llm",
    "multi-agent",
    "orchestration",
    "workflow"
  ],
  "homepage": "https://github.com/alexanderop/defineworkflow#readme",
  "bugs": {
    "url": "https://github.com/alexanderop/defineworkflow/issues"
  },
  "license": "MIT",
  "author": "Alexander Opalic",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexanderop/defineworkflow.git",
    "directory": "packages/workflow"
  },
  "bin": {
    "defineworkflow": "bin/defineworkflow.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.101.0",
    "acorn": "^8.16.0",
    "ajv": "^8.17.0",
    "esbuild": "^0.28.0",
    "ink": "^7.0.5",
    "neverthrow": "^8.1.0",
    "react": "^19.2.7",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@workflow/adapters": "workspace:*",
    "@workflow/cli": "workspace:*",
    "@workflow/core": "workspace:*",
    "@workflow/schema": "workspace:*",
    "@workflow/ui": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
