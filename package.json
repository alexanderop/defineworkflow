    "lefthook": "^1.10.0",
    "oxlint": "^0.11.0",
    "tsup": "^8.3.0",
    "turbo": "^2.2.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0"
  }
}
