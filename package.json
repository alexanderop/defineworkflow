{
  "name": "workflow-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "pnpm -r --filter=!./apps/* build",
    "typecheck": "pnpm -r --filter=!./apps/* build && pnpm -r typecheck",
    "lint": "oxlint . --ignore-pattern repos",
    "knip": "knip",
    "docs:dev": "pnpm --filter @workflow/docs dev",
    "docs:build": "pnpm --filter @workflow/docs build",
    "docs:preview": "pnpm --filter @workflow/docs preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --project unit --coverage",
    "test:e2e": "WORKFLOW_E2E=1 vitest run --project e2e",
    "newsletter": "pnpm --filter @workflow/newsletter build && pnpm --filter @workflow/examples vue-newsletter",
    "example": "pnpm -r build && pnpm --filter @workflow/examples haiku",
    "tri-harness": "pnpm -r build && pnpm --filter @workflow/examples tri-harness",
    "question": "pnpm -r build && pnpm --filter @workflow/examples question",
    "zod": "pnpm -r build && pnpm --filter @workflow/examples zod-mock",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "fast-check": "^4.8.0",
    "knip": "^6.14.2",
    "lefthook": "^2.1.9",
    "oxlint": "^1.67.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.7"
  }
}
